# PostgreSQL (database.py, subscriber, retry_worker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=mqtt_delivery
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# MQTT broker (redis_bridge, subscriber, retry_worker)
MQTT_HOST=localhost
MQTT_PORT=1883

# Redis (mqtt_queue, redis_bridge, publisher)
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: override queue keys (defaults: mqtt_queue, mqtt_queue_processing). Used by tests.
# MQTT_QUEUE_KEY=mqtt_queue
# MQTT_QUEUE_PROCESSING_KEY=mqtt_queue_processing
